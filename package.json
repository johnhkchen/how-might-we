{
  "name": "hmw-workshop",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:backend": "cd backend && go run main.go",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:worker": "cd worker && npx wrangler dev",
    "deploy": "npx sst deploy",
    "deploy:worker": "cd worker && npx wrangler deploy",
    "deploy:all": "bash scripts/deploy.sh",
    "verify:deploy": "bash scripts/verify-deploy.sh"
  },
  "devDependencies": {
    "sst": "^3.0.0",
    "aws-cdk-lib": "2.171.1",
    "constructs": "10.4.2"
  }
}
